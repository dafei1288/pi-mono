{
	"name": "@mariozechner/pi-mobile-server",
	"version": "0.63.1",
	"description": "Network bridge for pi coding agent — exposes RPC mode over WebSocket and HTTP for mobile clients",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"pi-mobile-server": "dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@mariozechner/pi-coding-agent": "^0.63.1",
		"bonjour-service": "^1.3.0",
		"qrcode-terminal": "^0.12.0",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"@types/qrcode-terminal": "^0.12.2",
		"@types/ws": "^8.18.0",
		"shx": "^0.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"keywords": [
		"ai",
		"agent",
		"coding",
		"mobile",
		"remote"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/badlogic/pi-mono.git",
		"directory": "packages/mobile-server"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
